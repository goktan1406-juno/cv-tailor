{
  "expo": {
    "name": "CV Tailor",
    "slug": "cv-tailor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cvtailor.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSDocumentPickerUsageDescription": "CV dosyanızı seçmek için doküman erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "CV dosyanızı seçmek için fotoğraf kitaplığı erişimi gereklidir.",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cvtailor.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "b29931d3-f199-4a52-862b-a58433c16fe7"
      }
    }
  }
}
